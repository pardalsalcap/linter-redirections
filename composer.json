{
    "name": "pardalsalcap/linter-redirections",
    "description": "Add on to manage 404 and redirections into linter and filament",
    "keywords": [
        "pardalsalcap",
        "laravel",
        "linter-redirections"
    ],
    "homepage": "https://github.com/pardalsalcap/linter-redirections",
    "license": "MIT",
    "authors": [
        {
            "name": "pardalsalcap",
            "email": "dani.casasnovas@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.14.0",
        "illuminate/contracts": "^11.0|^12.0",
        "filament/filament": "^5.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.13|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Pardalsalcap\\LinterRedirections\\": "src/",
            "Pardalsalcap\\LinterRedirections\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pardalsalcap\\LinterRedirections\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-linter-redirections --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pardalsalcap\\LinterRedirections\\LinterRedirectionsServiceProvider"
            ],
            "aliases": {
                "LinterRedirections": "Pardalsalcap\\LinterRedirections\\Facades\\LinterRedirections"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
